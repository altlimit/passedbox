<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="passedbox.exe"
        Arguments=""
        InstallLocation="C:\Program Files\My Company\My Product">
    </Installer>
    <PackageInformation
        PackageName="PassedBox"
        PackageDisplayName="PassedBox"
        PublisherName="CN=PassedBox"
        PublisherDisplayName="PassedBox"
        Version="0.1.0.0"
        PackageDescription="Encrypted File System">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.passedbox.fs"
                Description="Encrypted File System"
                DisplayName="PassedBox"
                ExecutableName="passedbox.exe"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>PassedBox</DisplayName>
            <PublisherDisplayName>PassedBox</PublisherDisplayName>
            <Description>Encrypted File System</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="passedbox.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
